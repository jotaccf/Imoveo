generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  GESTOR
  OPERADOR
}

enum TipoImovel {
  APARTAMENTO
  MORADIA
  LOJA
  ESCRITORIO
  INDUSTRIAL
  OUTRO
  GERAL
  PESSOAL
}

enum EstadoImovel {
  ACTIVO
  VAGO
  EM_OBRAS
  INACTIVO
}

enum TipoEntidade {
  FORNECEDOR
  INQUILINO
  PROPRIETARIO
  OUTRO
}

enum TipoRubrica {
  RECEITA
  GASTO
}

enum TipoFicheiro {
  EMITIDAS
  RECEBIDAS
}

enum OrigemClassificacao {
  AUTOMATICA
  MANUAL
}

enum TipoDocManual {
  RECIBO_VERDE
  CONTRATO_RENDA
  FATURA_PAPEL
  OUTRO
}

enum Periodicidade {
  MENSAL
  TRIMESTRAL
  ANUAL
}

enum EstadoContrato {
  ATIVO
  EXPIRADO
  TERMINADO
}

enum TipoDistribuicao {
  IGUAL
  PERCENTAGEM
  MANUAL
}

model Utilizador {
  id           String    @id @default(cuid())
  nome         String
  email        String    @unique
  passwordHash String
  role         Role      @default(OPERADOR)
  ativo        Boolean   @default(true)
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt
  ultimoLogin  DateTime?

  @@map("utilizadores")
}

model Imovel {
  id              String       @id @default(cuid())
  codigo          String       @unique
  nome            String
  tipo            TipoImovel
  morada          String?
  localizacao     String
  nifProprietario String?
  valorPatrimonial Decimal?    @db.Decimal(12, 2)
  areaMt2         Decimal?     @db.Decimal(8, 2)
  ordem           Int          @default(0)
  estado          EstadoImovel @default(ACTIVO)
  ativo           Boolean      @default(true)
  criadoEm        DateTime     @default(now())
  atualizadoEm    DateTime     @updatedAt

  // Dados para contrato
  fracaoAutonoma          String?
  andar                   String?
  freguesia               String?
  concelho                String?
  artigoMatricial         String?
  descricaoRP             String?
  licencaUtilizacao       String?
  dataLicenca             String?
  entidadeLicenca         String?
  incluirProprietarios    Boolean  @default(true)
  nomeProprietario1       String?
  ccProprietario1         String?
  nomeProprietario2       String?
  nifProprietario2        String?
  ccProprietario2         String?
  regimeCasamento         String?
  moradaProprietarios     String?
  dataContratoArrendamento DateTime?
  equipamentos            String?
  modeloDespesas          String   @default("INCLUIDO")
  incluirSubtracaoCaucao  Boolean  @default(false)
  plantaPath              String?

  // Propriedade adquirida vs arrendada
  tipoPropriedade        TipoPropriedade  @default(ARRENDADO)
  valorAquisicao         Decimal?         @db.Decimal(12, 2)
  dataAquisicao          DateTime?
  taxaDepreciacaoAnual   Decimal?         @db.Decimal(5, 2) @default(2.00)

  nifMaps            NifImovelMap[]
  classificacoes     FaturaClassificacao[]
  lancamentos        LancamentoManual[]
  fracoes            Fracao[]
  contratos          Contrato[]
  distribuicaoLinhas DistribuicaoLinha[]

  @@map("imoveis")
}

model Configuracao {
  id    String @id @default(cuid())
  chave String @unique
  valor String

  @@map("configuracoes")
}

// Configuracao fiscal por ano (CIRC, derrama, retencao, reporte prejuizos, tributacao autonoma)
model ConfiguracaoFiscal {
  ano                 Int     @id
  taxaIrcPme          Decimal @db.Decimal(5, 2)
  taxaIrcNormal       Decimal @db.Decimal(5, 2)
  limitePme           Decimal @db.Decimal(12, 2)
  derramaMunicipal    Decimal @db.Decimal(5, 2)
  taxaRetencao        Decimal @db.Decimal(5, 2)
  reportePrejuizoPct  Decimal @db.Decimal(5, 2) @default(65)
  regimePme           Boolean @default(true)

  // Tributacao autonoma — viaturas combustao (diesel/gasolina)
  taTaxaComBaixa      Decimal @db.Decimal(5, 2) @default(10)
  taTaxaComMedia      Decimal @db.Decimal(5, 2) @default(27.5)
  taTaxaComAlta       Decimal @db.Decimal(5, 2) @default(35)

  // Tributacao autonoma — viaturas hibrido plug-in
  taTaxaHibBaixa      Decimal @db.Decimal(5, 2) @default(5)
  taTaxaHibMedia      Decimal @db.Decimal(5, 2) @default(10)
  taTaxaHibAlta       Decimal @db.Decimal(5, 2) @default(17.5)

  // Tributacao autonoma — viaturas GPL/GNV
  taTaxaGplBaixa      Decimal @db.Decimal(5, 2) @default(7.5)
  taTaxaGplMedia      Decimal @db.Decimal(5, 2) @default(15)
  taTaxaGplAlta       Decimal @db.Decimal(5, 2) @default(27.5)

  // Tributacao autonoma — viaturas electricas
  taTaxaElectrica     Decimal @db.Decimal(5, 2) @default(10)
  taLimiteElectricoIsento Decimal @db.Decimal(12, 2) @default(62500)

  // Tiers viaturas (combustao/hibrido/GPL)
  taLimiteViaturaBaixa Decimal @db.Decimal(12, 2) @default(27500)
  taLimiteViaturaAlta  Decimal @db.Decimal(12, 2) @default(35000)

  // Limites fiscais dedutibilidade (acima nao deduz)
  limiteDeducaoCombustao  Decimal @db.Decimal(12, 2) @default(30000)
  limiteDeducaoGpl        Decimal @db.Decimal(12, 2) @default(37500)
  limiteDeducaoHibrido    Decimal @db.Decimal(12, 2) @default(50000)
  limiteDeducaoElectrico  Decimal @db.Decimal(12, 2) @default(62500)

  // Outras TA
  taTaxaRepresentacao Decimal @db.Decimal(5, 2) @default(10)
  taTaxaNaoDocumentadas Decimal @db.Decimal(5, 2) @default(50)
  taAgravamentoPrejuizoPp Decimal @db.Decimal(5, 2) @default(10)

  criadoEm            DateTime @default(now())
  atualizadoEm        DateTime @updatedAt

  @@map("configuracoes_fiscais")
}

enum TipoPropriedade {
  ARRENDADO
  ADQUIRIDO
}

enum TipoActivoFixo {
  VIATURA_LIGEIRA
  VIATURA_PESADA
  EQUIPAMENTO
  OUTRO
}

enum TipoCombustivel {
  COMBUSTAO
  HIBRIDO_PLUG_IN
  GPL_GNV
  ELECTRICO
}

model ActivoFixo {
  id                    String           @id @default(cuid())
  nome                  String
  tipo                  TipoActivoFixo
  combustivel           TipoCombustivel?
  matricula             String?
  valorAquisicao        Decimal          @db.Decimal(12, 2)
  dataAquisicao         DateTime
  taxaDepreciacaoAnual  Decimal          @db.Decimal(5, 2) @default(25)
  alienadoEm            DateTime?
  valorAlienacao        Decimal?         @db.Decimal(12, 2)
  notas                 String?
  criadoEm              DateTime         @default(now())
  atualizadoEm          DateTime         @updatedAt

  @@index([tipo])
  @@map("activos_fixos")
}

model PagamentoConta {
  id          String   @id @default(cuid())
  ano         Int
  prestacao   Int      // 1, 2 ou 3
  valor       Decimal  @db.Decimal(12, 2)
  dataPagamento DateTime
  notas       String?
  criadoEm    DateTime @default(now())

  @@unique([ano, prestacao])
  @@index([ano])
  @@map("pagamentos_conta")
}

enum EstadoFracao {
  OCUPADO
  VAGO
  EM_OBRAS
}

model Fracao {
  id                  String       @id @default(cuid())
  imovelId            String
  nome                String
  renda               Decimal      @db.Decimal(12, 2)
  nifInquilino        String?
  dataEntradaMercado  DateTime?
  estado              EstadoFracao @default(VAGO)
  criadoEm            DateTime     @default(now())
  atualizadoEm        DateTime     @updatedAt

  // Dados para contrato
  letraQuarto         String?
  tipoQuarto          String?
  casaBanho           String?
  mobilia             String?
  numeroAnexo         String?

  imovel             Imovel              @relation(fields: [imovelId], references: [id])
  nifMaps            NifImovelMap[]
  classificacoes     FaturaClassificacao[]
  lancamentos        LancamentoManual[]
  contratos          Contrato[]
  distribuicaoLinhas DistribuicaoLinha[]

  @@map("fracoes")
}

model Entidade {
  id       String       @id @default(cuid())
  nif      String       @unique
  nome     String
  tipo     TipoEntidade @default(FORNECEDOR)
  criadoEm DateTime     @default(now())

  nifMaps               NifImovelMap[]
  distribuicaoTemplates DistribuicaoTemplate[]

  @@map("entidades")
}

model NifImovelMap {
  id          String   @id @default(cuid())
  nifEntidade String
  imovelId    String?
  rubricaId   String
  fracaoId    String?
  ativo       Boolean  @default(true)
  criadoEm    DateTime @default(now())

  imovel   Imovel?   @relation(fields: [imovelId], references: [id])
  rubrica  Rubrica   @relation(fields: [rubricaId], references: [id])
  entidade Entidade? @relation(fields: [nifEntidade], references: [nif])
  fracao   Fracao?   @relation(fields: [fracaoId], references: [id])

  @@unique([nifEntidade, imovelId])
  @@index([nifEntidade])
  @@map("nif_imovel_map")
}

model Rubrica {
  id        String      @id @default(cuid())
  codigo    String      @unique
  nome      String
  tipo      TipoRubrica @default(GASTO)
  ordem     Int         @default(0)
  dedutivel Boolean     @default(true)

  nifMaps               NifImovelMap[]
  classificacoes        FaturaClassificacao[]
  lancamentos           LancamentoManual[]
  faturasSugeridas      Fatura[]              @relation("RubricaSugerida")
  distribuicaoTemplates DistribuicaoTemplate[]

  @@map("rubricas")
}

model Importacao {
  id           String       @id @default(cuid())
  filename     String
  hashFicheiro String       @unique
  periodo      String
  tipoFicheiro TipoFicheiro
  totalFaturas Int          @default(0)
  novas        Int          @default(0)
  duplicadas   Int          @default(0)
  pendentes    Int          @default(0)
  criadoEm     DateTime     @default(now())

  faturas Fatura[]

  @@map("importacoes")
}

model Fatura {
  id              String   @id @default(cuid())
  hashFatura      String   @unique
  nifEmitente     String
  serieDoc        String
  numeroDoc       String
  nifDestinatario String?
  nomeEmitente    String?
  dataFatura      DateTime
  totalSemIva     Decimal  @db.Decimal(12, 2)
  totalIva        Decimal  @db.Decimal(12, 2)
  totalComIva     Decimal  @db.Decimal(12, 2)
  tipoDocumento   String?
  importacaoId    String
  rubricaSugeridaId String?
  criadoEm        DateTime @default(now())

  importacao      Importacao           @relation(fields: [importacaoId], references: [id])
  rubricaSugerida Rubrica?             @relation("RubricaSugerida", fields: [rubricaSugeridaId], references: [id])
  classificacoes  FaturaClassificacao[]

  @@unique([nifEmitente, serieDoc, numeroDoc])
  @@index([nifEmitente])
  @@index([dataFatura])
  @@index([nifDestinatario])
  @@map("faturas")
}

model FaturaClassificacao {
  id             String              @id @default(cuid())
  faturaId       String
  imovelId       String
  rubricaId      String
  fracaoId       String?
  origem         OrigemClassificacao @default(AUTOMATICA)
  confirmado     Boolean             @default(false)
  valorAtribuido Decimal?            @db.Decimal(12, 2)
  percentagem    Decimal?            @db.Decimal(5, 2)
  criadoEm       DateTime            @default(now())
  atualizadoEm   DateTime            @updatedAt

  fatura  Fatura  @relation(fields: [faturaId], references: [id])
  imovel  Imovel  @relation(fields: [imovelId], references: [id])
  rubrica Rubrica @relation(fields: [rubricaId], references: [id])
  fracao  Fracao? @relation(fields: [fracaoId], references: [id])

  @@index([faturaId])
  @@map("fatura_classificacao")
}

model LancamentoManual {
  id            String         @id @default(cuid())
  tipoDoc       TipoDocManual  @default(RECIBO_VERDE)
  numeroDoc     String?
  fornecedor    String
  nifFornecedor String?
  imovelId      String
  rubricaId     String
  dataDoc       DateTime
  valorSemIva     Decimal        @db.Decimal(12, 2)
  taxaIva         Int            @default(0)
  totalComIva     Decimal        @db.Decimal(12, 2)
  retencaoFonte   Int            @default(0)
  valorRetencao   Decimal?       @db.Decimal(12, 2)
  recorrente    Boolean        @default(false)
  periodicidade Periodicidade?
  dataFim       DateTime?
  notas         String?
  fracaoId      String?
  criadoEm      DateTime       @default(now())
  atualizadoEm  DateTime       @updatedAt

  imovel  Imovel  @relation(fields: [imovelId], references: [id])
  rubrica Rubrica @relation(fields: [rubricaId], references: [id])
  fracao  Fracao? @relation(fields: [fracaoId], references: [id])

  @@index([imovelId])
  @@index([dataDoc])
  @@map("lancamentos_manuais")
}

model DistribuicaoTemplate {
  id           String            @id @default(cuid())
  nifEntidade  String
  rubricaId    String
  tipo         TipoDistribuicao  @default(IGUAL)
  nome         String?
  ativo        Boolean           @default(true)
  criadoEm     DateTime          @default(now())
  atualizadoEm DateTime          @updatedAt

  entidade Entidade            @relation(fields: [nifEntidade], references: [nif])
  rubrica  Rubrica             @relation(fields: [rubricaId], references: [id])
  linhas   DistribuicaoLinha[]

  @@unique([nifEntidade])
  @@map("distribuicao_templates")
}

model DistribuicaoLinha {
  id          String   @id @default(cuid())
  templateId  String
  imovelId    String
  fracaoId    String?
  percentagem Decimal? @db.Decimal(5, 2)
  ordem       Int      @default(0)

  template DistribuicaoTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  imovel   Imovel               @relation(fields: [imovelId], references: [id])
  fracao   Fracao?              @relation(fields: [fracaoId], references: [id])

  @@unique([templateId, imovelId])
  @@map("distribuicao_linhas")
}

model Contrato {
  id               String          @id @default(cuid())
  fracaoId         String
  imovelId         String
  nomeInquilino    String
  nifInquilino     String?
  contacto         String?
  nomeFiador       String?
  nifFiador        String?
  contactoFiador   String?
  parentesco       String?
  valorRenda       Decimal         @db.Decimal(12, 2)
  dataInicio       DateTime
  dataFim          DateTime?
  renovacaoAuto    Boolean         @default(true)
  periodoRenovacao Int             @default(12)
  caucao           Decimal?        @db.Decimal(12, 2)
  notas            String?
  comunicadoAT     Boolean         @default(false)
  dataComunicacaoAT DateTime?
  estado           EstadoContrato  @default(ATIVO)

  // Dados pessoais inquilino para contrato PDF
  genero              String?
  nacionalidade       String?
  tipoDocumento       String?
  numDocumento        String?
  validadeDocumento   DateTime?
  estadoCivil         String?
  naturalidade        String?
  moradaInquilino     String?
  usarMoradaImovel    Boolean  @default(true)
  localAssinatura     String?
  dataAssinatura      DateTime?
  contratoPdfPath     String?
  contratoAssinadoPath String?
  criadoEm         DateTime        @default(now())
  atualizadoEm     DateTime        @updatedAt

  fracao  Fracao @relation(fields: [fracaoId], references: [id])
  imovel  Imovel @relation(fields: [imovelId], references: [id])

  @@index([fracaoId])
  @@index([imovelId])
  @@index([dataFim])
  @@map("contratos")
}
